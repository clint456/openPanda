# ============================================================
# .env.development — 前端开发环境（Vite 自动加载）
#
# 何时生效:
#   npm run dev   → Vite 自动读取此文件
#
# 注意:
#   - 仅包含 VITE_ 前缀的变量（其他前缀不会暴露给前端代码）
#   - 不是机密文件，可提交到 Git
#   - 开发时 API 请求通过 Vite proxy 转发到本地后端
# ============================================================

# API 基础地址（开发环境 Vite proxy 代理到 localhost:8080）
VITE_API_BASE_URL=http://localhost:8080/api/v1

# 应用标题
VITE_APP_TITLE=开源熊猫 技术交流平台
