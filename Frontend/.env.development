// ============================================================
// 开发环境变量
// 说明：以 VITE_ 开头的变量才会暴露给前端代码
//       在代码中使用：import.meta.env.VITE_API_BASE_URL
// ============================================================

# API 基础地址（开发环境通过 Vite proxy 代理）
VITE_API_BASE_URL=http://localhost:8080/api/v1

# 应用标题
VITE_APP_TITLE=开源熊猫 技术交流平台
