# ============================================================
# .env — 服务器环境变量（由 GitHub Actions 自动生成，不要手动编辑）
#
# 所有敏感值在 GitHub → Settings → Secrets → Actions 中管理
# 每次 CI/CD 部署时自动写入服务器
# ============================================================

DOCKERHUB_USER=clintonluo
DB_PASSWORD=postgres
DB_NAME=openpanda
JWT_SECRET=change-me-to-a-strong-secret-in-production
ADMIN_USERNAME=admin
ADMIN_PASSWORD=请修改为你自己的密码
