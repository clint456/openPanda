# ============================================================
# .env.prod.example — 生产环境变量模板（仅供生产部署参考）
#
# 用法（仅生产服务器上执行）:
#   cp deploy/.env.prod.example .env    # 复制为 .env
#   编辑 .env 填入真实值           # .env 已在 .gitignore 中，不会提交
#
# ⚠️ 本地开发不需要此文件！
#   - Go 代码有内置默认值（config.go）
#   - docker-compose.yml 有内置默认值（${VAR:-default}）
#   - 直接 docker-compose up -d 即可启动
#
# 生产部署时 docker-compose.prod.yml 会自动读取 .env 文件。
# CI/CD 中这些值通过 GitHub Secrets 注入。
# ============================================================

# ── DockerHub（CI/CD 镜像推送用）──
DOCKERHUB_USER=clintonluo

# ── 数据库 ──
DB_USER=postgres
DB_PASSWORD=your-production-db-password
DB_NAME=openpanda

# ── 安全 ──
# 生成方式: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-generated-64-char-hex-secret

# ── 管理员登录 ──
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your-strong-admin-password

# ── 站点 URL（用于 sitemap 等）──
SITE_URL=https://your-domain.com

# ── AI 供应商（可选，也支持管理后台页面在线配置）──
DEEPSEEK_API_KEY=
QWEN_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
